# Database backend: "sqlite" or "postgres"
DB_BACKEND=postgres

# SQLite (used when DB_BACKEND=sqlite)
SQLITE_PATH=antiterror.db

# PostgreSQL (used when DB_BACKEND=postgres)
POSTGRES_DSN=postgresql://antiterror:antiterror@localhost:5432/antiterror
POSTGRES_DB=antiterror
POSTGRES_USER=antiterror
POSTGRES_PASSWORD=antiterror
POSTGRES_PORT=5432

# API server
API_HOST=0.0.0.0
API_PORT=8000

# JWT authentication
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=48